=======
# Lint only changed packages. Packages in nested Go modules (e.g.
# test/antithesis) are skipped: golangci-lint can only typecheck
# packages belonging to the module it runs in, and CI doesn't lint
# them either.
changed_pkgs=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' \
  | xargs -n1 dirname \
  | sort -u \
  | while read -r dir; do
      mod_dir=$dir
      while [ "$mod_dir" != "." ] && [ ! -f "$mod_dir/go.mod" ]; do
        mod_dir=$(dirname "$mod_dir")
      done
      if [ "$mod_dir" = "." ]; then
        echo "$dir/..."
      else
        echo "skipping $dir (nested module $mod_dir)" >&2
      fi
    done)

if [ -z "$changed_pkgs" ]; then
  echo "No staged .go files, skipping lint."
