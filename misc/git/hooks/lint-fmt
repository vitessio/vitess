# Required version of golangci-lint, sourced from build.env (single source of truth)
REQUIRED_VERSION=$(grep "^export GOLANGCI_LINT_VER=" "$(git rev-parse --show-toplevel)/build.env" | cut -d= -f2)
if [ -z "$REQUIRED_VERSION" ]; then
  echo "Could not determine required golangci-lint version from build.env"
  exit 1
fi
