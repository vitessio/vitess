# golangci-lint is version-pinned in its own module; `go tool` builds and
# caches the pinned version on demand.
GOLANGCI_LINT_MODFILE="$(git rev-parse --show-toplevel)/tools/golangci-lint/go.mod"
>>>>>>> dc9b73d86d (build: move dev tools into per-tool Go modules (#20293))

# Lint only changed packages. Packages in nested Go modules (e.g.
# test/antithesis) are skipped: golangci-lint can only typecheck
# packages belonging to the module it runs in, and CI doesn't lint
# them either.
changed_pkgs=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' \
  | xargs -n1 dirname \
  | sort -u \
  | while read -r dir; do
      mod_dir=$dir
      while [ "$mod_dir" != "." ] && [ ! -f "$mod_dir/go.mod" ]; do
        mod_dir=$(dirname "$mod_dir")
      done
      if [ "$mod_dir" = "." ]; then
        echo "$dir/..."
      else
        echo "skipping $dir (nested module $mod_dir)" >&2
      fi
    done)

if [ -z "$changed_pkgs" ]; then
  echo "No staged .go files, skipping lint."
  exit 0
fi

echo "Linting staged changes..."
go tool -modfile="$GOLANGCI_LINT_MODFILE" golangci-lint run --new-from-rev=HEAD $changed_pkgs
