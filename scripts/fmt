#!/usr/bin/env bash

# Formats the given Go files with the pinned golangci-lint formatters
# (gofumpt and goimports) configured in .golangci.yml.
#
# Usage: scripts/fmt <go-files>

set -euo pipefail

script_path="${BASH_SOURCE[0]}"
if [ -L "$script_path" ]; then
  script_path="$(readlink "$script_path")"
fi

repo_root="$(cd "$(dirname "$script_path")/.." && pwd)"

exec go tool -modfile="$repo_root/tools/golangci-lint/go.mod" golangci-lint fmt -c "$repo_root/.golangci.yml" "$@"
